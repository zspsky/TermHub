{
	admin off
}

:{$CADDY_HTTP_PORT:7860} {
	basic_auth {
		{$CADDY_AUTH_USER:admin} {$CADDY_AUTH_HASH}
	}

	@ttyd path_regexp ttyd ^/ttyd/(77[0-9][0-9])(/.*)?$
	handle @ttyd {
		reverse_proxy 127.0.0.1:{re.ttyd.1}
	}

	import /etc/caddy/nodes.caddy

	handle {
		reverse_proxy 127.0.0.1:{$TASK_MANAGER_INTERNAL_PORT:7861}
	}
}
